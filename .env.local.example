# Copy to .env.local for local development.

# Base URL of the Django API. Read server-side by the BFF proxy
# (app/bff/*) which attaches the JWT from httpOnly cookies. The browser never
# calls this URL directly — it talks to the same-origin /bff proxy — so the
# token is never exposed to client JavaScript.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: if set, overrides NEXT_PUBLIC_API_URL for the server-side proxy only
# (useful when the browser and the Next.js server reach Django at different
# hostnames, e.g. in Docker). Leave unset for local dev.
# API_URL=http://localhost:8000
